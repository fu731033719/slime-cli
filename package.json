{
  "name": "slime-cli",
  "version": "0.1.0",
  "description": "Slime - Cli",
  "main": "electron/main.js",
  "bin": {
    "slime": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "start:cli": "node dist/index.js",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:build:linux": "npm run build && electron-builder --linux",
    "watch": "tsc --watch",
    "test": "tsx --test tests/**/*.test.ts",
    "report": "node dist/index.js chat --exec '/report'",
    "clean-logs": "node scripts/clean-logs.mjs"
  },
  "keywords": [
    "cli",
    "ai",
    "assistant",
    "slime",
    "chatbot",
    "command-line",
    "typescript"
  ],
  "author": "Slime Studio",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/fu731033719/slime-cli.git"
  },
  "bugs": {
    "url": "https://github.com/fu731033719/slime-cli/issues"
  },
  "homepage": "https://github.com/fu731033719/slime-cli#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@larksuiteoapi/node-sdk": "^1.58.0",
    "axios": "^1.6.2",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "deasync": "^0.1.31",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "glob": "^10.3.10",
    "gray-matter": "^4.0.3",
    "inquirer": "^8.2.7",
    "ora": "^5.4.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/deasync": "^0.1.5",
    "@types/express": "^5.0.6",
    "@types/glob": "^8.1.0",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.10.5",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.18.1",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "playwright": "^1.58.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "build": {
    "appId": "com.slimecli.app",
    "productName": "Slime",
    "icon": null,
    "directories": {
      "output": "release"
    },
    "asar": false,
    "publish": {
      "provider": "github",
      "owner": "fu731033719",
      "repo": "slime-cli"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "dashboard/**/*",
      "prompts/**/*",
      "skills/agent-browser/**/*",
      "skills/_tool-skills/**/*",
      "skills/report/**/*",
      "skills/self-evolution/**/*",
      "skills/skill-publish/**/*",
      "skills/remember/**/*",
      "skills/README.md",
      "skill-registry.json",
      ".env.example",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "node_modules",
        "to": "node_modules",
        "filter": [
          "**/*.node",
          "**/*.js",
          "**/*.json",
          "!**/.bin/**",
          "!**/test/**",
          "!**/tests/**",
          "!**/*.md",
          "!electron/**",
          "!electron-builder/**",
          "@types/**",
          "!typescript/**"
        ]
      }
    ],
    "extraFiles": [
      {
        "from": "build-resources/node",
        "to": "node",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg"
      ],
      "icon": "build-resources/icon.png"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build-resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Slime"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "build-resources/icon.png"
    },
    "dmg": {
      "title": "Slime",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}

