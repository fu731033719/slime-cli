# Slime environment example

# Model provider
GAUZ_LLM_PROVIDER=deepseek
GAUZ_LLM_API_KEY=your_api_key
GAUZ_LLM_API_BASE=https://api.deepseek.com/v1
GAUZ_LLM_MODEL=deepseek-chat

# Optional log upload
LOG_UPLOAD_ENABLED=false
LOG_UPLOAD_SERVER_URL=http://127.0.0.1:3000
LOG_UPLOAD_INTERVAL_MINUTES=30

# Feishu
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_BOT_OPEN_ID=
# FEISHU_BOT_ALIASES=史莱姆,slime

# CatsCompany
# CATSCOMPANY_SERVER_URL=
# CATSCOMPANY_API_KEY=
# CATSCOMPANY_HTTP_BASE_URL=

